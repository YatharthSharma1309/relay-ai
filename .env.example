# PostgreSQL connection string
# Local: run `npx prisma dev` and paste the postgres:// URL it prints (NOT prisma+postgres://)
# Production: Neon pooled URL with sslmode=require
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# Clerk — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-clerk-publishable-key"
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
CLERK_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# OpenRouter — https://openrouter.ai/keys (primary AI provider)
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"
OPENROUTER_CHAT_MODEL="openrouter/free"
OPENROUTER_EMBEDDING_MODEL=""
# Optional fallback if you use OpenAI-compatible keys directly
# OPENAI_API_KEY="sk-your-openai-key"
# Optional alias for OPENROUTER_CHAT_MODEL
# AI_CHAT_MODEL="openrouter/free"
APP_URL="http://localhost:3000"

# Optional: public recruiter demo (no Clerk) — set on Vercel only, not for real production
# PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_PUBLIC_DEMO_MODE=true
# AUTH_BYPASS=true
# NEXT_PUBLIC_AUTH_BYPASS=true
# DEMO_SEED_SECRET="your-secret-here"
# CI/E2E only — allows AUTH_BYPASS in production builds during Playwright runs
# E2E_AUTH_BYPASS=true

# Demo workspace (used when AUTH_BYPASS=true or demo seed scripts)
DEMO_ORGANIZATION_SLUG="demo-company"
DEMO_USER_EMAIL="admin@demo.com"
# Optional: fixed widget key for local/CI e2e tests
# DEMO_WIDGET_KEY="wk_test_e2e_demo_widget_key"
# Optional: enable dashboard Playwright tests (requires AUTH_BYPASS + seeded demo org)
# PLAYWRIGHT_DASHBOARD=1

# Optional: required in production to call POST /api/demo/seed
# DEMO_SEED_SECRET="your-secret-here"

# Widget visitor session signing (recommended in production)
# WIDGET_VISITOR_SECRET="long-random-secret"

# Optional: distributed rate limiting (falls back to in-memory when unset)
# UPSTASH_REDIS_REST_URL="https://your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
