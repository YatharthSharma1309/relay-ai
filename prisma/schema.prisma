generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemberRole {
  ADMIN
  AGENT
}

enum ConversationChannel {
  ADMIN
  WIDGET
  HELP_CENTER
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  clerkOrgId      String?  @unique
  widgetPublicKey String?  @unique
  widgetEnabled   Boolean  @default(true)
  settings        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members                 OrganizationMember[]
  documents               Document[]
  conversations           Conversation[]
  tickets                 Ticket[]
  jobs                    Job[]
  recruitmentAuditEvents  RecruitmentAuditEvent[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  clerkUserId String?  @unique
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     OrganizationMember[]
  ticketComments  TicketComment[]
  assignedTickets Ticket[]             @relation("AssignedTickets")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(AGENT)
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Document {
  id             String         @id @default(cuid())
  organizationId String
  title          String
  fileName       String
  fileType       String
  filePath       String? /// Legacy; uploads are processed in-memory (always null)
  storageKey     String? /// Reserved for future object storage integration
  fileSize       Int
  status         DocumentStatus @default(PROCESSING)
  errorMessage   String?
  chunkCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]
}

model DocumentChunk {
  id         String @id @default(cuid())
  documentId String
  content    String
  chunkIndex Int
  tokenCount Int    @default(0)
  embedding  Json?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Conversation {
  id             String              @id @default(cuid())
  organizationId String
  visitorId      String?
  channel        ConversationChannel @default(ADMIN)
  title          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]
  tickets      Ticket[]

  @@index([organizationId, visitorId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  sources        Json?
  helpful        Boolean?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Ticket {
  id             String         @id @default(cuid())
  organizationId String
  conversationId String?
  assigneeId     String?
  title          String
  description    String
  requesterEmail String?
  requesterName  String?
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  resolvedAt     DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assignee     User?           @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments     TicketComment[]

  @@index([organizationId, status])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  content   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
}

model Job {
  id                        String      @id @default(cuid())
  organizationId            String
  title                     String
  description               String
  requiredSkills            String
  preferredSkills           String      @default("[]")
  experienceLevel           String      @default("")
  minYearsExperience        Int?
  educationRequirements     String      @default("[]")
  certifications            String      @default("[]")
  roleType                  String      @default("")
  pendingHireCandidateId    String?
  pendingHireExpiresAt      DateTime?
  pendingHirePreviousStatus String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidates   Candidate[]

  @@index([organizationId])
  @@index([createdAt])
}

model Candidate {
  id                  String    @id @default(cuid())
  jobId               String
  displayName         String
  fileName            String?
  mimeType            String?
  filePath            String? /// Always null; resumes processed in-memory only
  rawText             String
  parseStatus         String    @default("ok")
  status              String    @default("new")
  statusBeforeArchive String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job      Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  analysis CandidateAnalysis?

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model CandidateAnalysis {
  id                 String   @id @default(cuid())
  candidateId        String   @unique
  summary            String
  extractedSkills    String
  matchScore         Int
  scoreBreakdown     String   @default("{}")
  matchRationale     String
  missingSkills      String
  interviewQuestions String
  modelId            String?
  analyzedAt         DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model RecruitmentAuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  action         String
  entityType     String
  entityId       String?
  actorId        String?
  metadata       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
